# Environment Variables — Clínica ABA
# Copie este arquivo para .env.local e preencha os valores

# ==============================
# Banco de Dados (PostgreSQL)
# ==============================
DATABASE_URL="postgresql://aba_user:aba_password@localhost:5432/clinica_aba"

# ==============================
# NextAuth.js
# ==============================
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-aqui"
NEXTAUTH_URL="http://localhost:3000"

# ==============================
# E-mail (SMTP via Nodemailer)
# ==============================
# Para Gmail: ative "App Password" em https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
EMAIL_FROM="Clínica ABA <seu-email@gmail.com>"

# ==============================
# Multi-tenant (branch: saas)
# ==============================
# Domínio base usado para montar links de convite de novas clínicas.
# Exemplo: APP_DOMAIN=agendaaba.com.br → link: clinicafeliz.agendaaba.com.br/set-password/...
APP_DOMAIN="agendaaba.com.br"

# Slug da clínica para desenvolvimento local sem subdomínio.
# Em produção o slug é lido automaticamente do subdomínio (clinicafeliz.seusistema.com.br).
# Não defina em produção — deixe em branco para usar a detecção por subdomínio.
# CLINIC_SLUG="minha-clinica"

# ==============================
# Super-admin (provisionamento de clínicas)
# ==============================
# Usados pelo script prisma/seed-super-admin.ts para criar/atualizar a conta
# que acessa o painel /super-admin. Rode o script novamente após trocar a senha aqui.
SUPER_ADMIN_EMAIL="admin@seusistema.com.br"
SUPER_ADMIN_PASSWORD="defina-uma-senha-forte"
